// ============================================================
// DATABASE ARCHITECTURE - Chat Application (NestJS + PostgreSQL)
// ============================================================
// Improved version - Optimized for real-time chat

Table user {
  id int [pk, increment]

  name varchar [not null]
  password varchar [not null]
  email varchar [not null]

  avatarUrl varchar                    // Profile picture URL

  status int [not null, default: 1]     // 1=EMAIL_INACTIVE, 2=ACTIVE, 3=INACTIVE
  role int [not null, default: 1]       // 1=USER, 2=ADMIN

  lastSeenAt timestamptz               // Last online timestamp

  refreshToken varchar

  created_at timestamptz [not null]
  updated_at timestamptz [not null]
  deleted_at timestamptz
}

Table conversation {
  id int [pk, increment]

  type int [not null]                   // 1=GROUP, 2=PRIVATE
  name varchar                          // Nullable for Private chat (can be auto-generated)
  hash varchar [not null]               // Used to create unique conversation

  lastMessageId int                     // FK -> message.id (nullable, optional)
  lastActivityAt timestamptz            // Last activity time (very important for sorting)

  created_at timestamptz [not null]
  updated_at timestamptz [not null]
  deleted_at timestamptz
}

Table conversation_participants {
  id int [pk, increment]

  userId int [not null]
  conversationId int [not null]

  role int [not null]                   // 0=MEMBER, 1=ADMIN, 2=OWNER
  lastReadMessageId int                 // Used to calculate unread count (nullable for new members)
  joinedAt timestamptz                  // When user joined the conversation

  created_at timestamptz [not null]
  updated_at timestamptz [not null]
  deleted_at timestamptz

  Note: 'Each user can only participate once per conversation (Unique userId + conversationId)'
}

Table message {
  id int [pk, increment]

  conversationId int [not null]
  senderId int                          // Can be NULL if user is deleted

  content text                          // Use TEXT instead of VARCHAR
  type int [not null, default: 1]       // 1=TEXT, 2=IMAGE, 3=VIDEO, 4=SYSTEM, 5=FILE,...

  replyToId int                         // Supports message reply (self-reference FK)
  metadata jsonb                        // Stores extra info (image url, file info, emoji,...)

  created_at timestamptz [not null]
  updated_at timestamptz [not null]
  deleted_at timestamptz

  Note: 'No UNIQUE(conversationId, senderId) - a user can send multiple messages'
}

// ============================================================
// RELATIONSHIPS
// ============================================================

Ref: conversation_participants.userId > user.id                  // ON DELETE CASCADE
Ref: conversation_participants.conversationId > conversation.id  // ON DELETE CASCADE

Ref: message.conversationId > conversation.id                    // ON DELETE RESTRICT
Ref: message.senderId > user.id                                  // ON DELETE SET NULL
Ref: message.replyToId > message.id                              // Self-reference

Ref: conversation.lastMessageId > message.id                     // Optional

// ============================================================
// INDEXES (for performance)
// ============================================================

